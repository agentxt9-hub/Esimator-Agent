# Staging environment variables — copy to /var/www/zenbid-staging/.env on the server
# NEVER commit the actual .env file — this example file only

# Flask
SECRET_KEY=generate-a-fresh-random-key-for-staging-not-shared-with-production
FLASK_ENV=production
REQUIRE_SECURE_CONFIG=1

# Database — staging logical DB on the same Postgres instance as production
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/zenbid_staging

# AI
ANTHROPIC_API_KEY=sk-ant-...

# Superadmin — your email; grants access to /admin panel
SUPERADMIN_EMAIL=agentxt9@gmail.com

# Email — can use the same SendGrid account with a staging sender
MAIL_SERVER=smtp.sendgrid.net
MAIL_PORT=587
MAIL_USERNAME=apikey
MAIL_PASSWORD=SG.xxxxxxxxxxxxxxxx
MAIL_DEFAULT_SENDER=staging@zenbid.io

# Monitoring — use a separate Sentry project for staging or same project with different environment tag
SENTRY_DSN=https://xxxxxxxx@oXXXXXX.ingest.sentry.io/XXXXXXX
LOG_LEVEL=INFO

# Debug — keep false even in staging
FLASK_DEBUG=false
