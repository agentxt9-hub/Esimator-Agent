# Copy this to .env on the server and fill in real values
# The .env file is gitignored and never committed

# Flask — required in production
SECRET_KEY=generate-a-long-random-string-at-least-32-chars
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/estimator_db
FLASK_ENV=production
REQUIRE_SECURE_CONFIG=1

# AI
ANTHROPIC_API_KEY=sk-ant-...

# Superadmin — your email; grants access to /admin panel on this instance
SUPERADMIN_EMAIL=agentxt9@gmail.com

# Monitoring
# Sentry DSN — get from sentry.io project settings. Leave blank to disable Sentry.
SENTRY_DSN=https://xxxxxxxx@oXXXXXX.ingest.sentry.io/XXXXXXX
# Log level — DEBUG | INFO | WARNING | ERROR (default: INFO)
LOG_LEVEL=INFO

# Debug — NEVER set to true in production
FLASK_DEBUG=false

# Email — SendGrid SMTP (required for password reset)
MAIL_SERVER=smtp.sendgrid.net
MAIL_PORT=587
MAIL_USERNAME=apikey
MAIL_PASSWORD=SG.xxxxxxxxxxxxxxxx
MAIL_DEFAULT_SENDER=noreply@zenbid.io
